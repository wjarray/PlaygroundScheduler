<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PlaygroundScheduler.Avalonia.App.App"
             xmlns:vm="using:PlaygroundScheduler.Avalonia.App.ViewModels"
             xmlns:views="using:PlaygroundScheduler.Avalonia.App.Views"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://PlaygroundScheduler.Avalonia.App/Styles/Buttons.axaml"/>
        <StyleInclude Source="avares://PlaygroundScheduler.Avalonia.App/Styles/Forms.axaml"/>
        <StyleInclude Source="avares://PlaygroundScheduler.Avalonia.App/Styles/Layout.axaml"/>
    </Application.Styles>
    <Application.DataTemplates>
        <DataTemplate DataType="vm:DashboardViewModel">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="vm:JobsViewModel">
            <views:JobsView/>
        </DataTemplate>
        <DataTemplate DataType="vm:SettingsViewModel">
            <views:SettingsView/>
        </DataTemplate>
    </Application.DataTemplates>
</Application>
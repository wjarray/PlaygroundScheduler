<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PlaygroundScheduler.Avalonia.App.ViewModels"
             x:Class="PlaygroundScheduler.Avalonia.App.Views.Components.SideBarView"
             x:DataType="vm:MainWindowViewModel">
    
            <Border Padding="12" Classes="sidebar">
                <StackPanel Spacing="8">
                    <Button Content="Dashboard" Command="{Binding ShowDashboardCommand}"/>
                    <Button Content="Jobs" Command="{Binding ShowJobsCommand}"/>
                    <Button Content="Settings" Command="{Binding ShowSettingsCommand}"/>
                </StackPanel>
            </Border>
</UserControl>

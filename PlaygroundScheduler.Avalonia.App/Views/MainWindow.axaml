<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:PlaygroundScheduler.Avalonia.App.ViewModels"
        xmlns:components="using:PlaygroundScheduler.Avalonia.App.Views.Components"
        x:Class="PlaygroundScheduler.Avalonia.App.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        mc:Ignorable="d" 
        d:DesignWidth="1400" 
        d:DesignHeight="900"
        Title="PlaygroundScheduler">
        
        <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="240,*">
                <!-- Header -->
                <Border Grid.Row="0" Grid.ColumnSpan="2" Padding="12" Classes="topbar">
                        <TextBlock Text="Scheduler" FontSize="20" FontWeight="Bold"/>
                </Border>                
                
                <!-- SideBar -->
                <components:SideBarView Grid.Row="1" Grid.Column="0"/>

                <!-- Workspace -->
                <Border Grid.Row="1" Grid.Column="1" Padding="16" Classes="workspace">
                        <ContentControl Content="{Binding CurrentViewModel}"/>
                </Border>
                
                <!-- StatusBar -->
                <components:StatusBarView Grid.Row="2" Grid.ColumnSpan="2"/>
        </Grid>
</Window>

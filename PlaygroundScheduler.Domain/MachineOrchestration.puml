'       Repositories -right- [JobRep]  
'       IRepository -right-  [JobRunRep] 
'    }
'    [LocalJobRunner]
'    [JobRep]
'      
'    package Service {
'          [JobRunService] -down- LocalJobRunner
'    }
'    
'
'       package Registries {
'            [RunningJobRegistries]  -down- IRegistry
'        }
'
'       package Store {
'            [JobRunOutputStore] 
'       }  
'}
'    




@enduml
